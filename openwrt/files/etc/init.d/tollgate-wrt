#!/bin/sh /etc/rc.common

# procd init script for tollgate-wrt (Rust edition).
# Service name `tollgate-wrt` is an interop requirement — must match
# the Go predecessor so the existing init.d slot is reused on upgrade.
#
# Binds 127.0.0.1:2121 (HTTP) and /var/run/tollgate.sock (CLI).
# Runs as root (needs ndsctl access).
# Logs to logread -e tollgate.

START=95
USE_PROCD=1

EXTRA_COMMANDS="status reload"
EXTRA_HELP="        status          Check service status
        reload          Reload service (graceful restart)"

start_service() {
	procd_open_instance
	procd_set_param command /usr/bin/tollgate-module-basic-rust
	procd_set_param directory /
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param env RUST_LOG=info
	procd_set_param respawn 3 5 0
	procd_set_param limits core=unlimited
	procd_close_instance
}

stop_service() {
	# procd handles process termination; clean up the CLI socket
	rm -f /var/run/tollgate.sock
}

reload_service() {
	# Graceful restart: procd restart reloads config + re-binds sockets
	/etc/init.d/tollgate-wrt restart
}

status() {
	if pgrep -f "tollgate-module-basic-rust" >/dev/null; then
		echo "tollgate-wrt (Rust) is running"
		nds_status=$(/etc/init.d/nodogsplash status 2>/dev/null || echo "unknown")
		echo "NoDogSplash: $nds_status"
		return 0
	else
		echo "tollgate-wrt (Rust) is not running"
		return 1
	fi
}